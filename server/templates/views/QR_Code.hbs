<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quick Dine_Delight</title>
    <link rel="stylesheet" href="/css/homepage.css">
    <script src="https://kit.fontawesome.com/ce75bd9e29.js" crossorigin="anonymous"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@1&family=Inter:wght@400;500;700&family=Lora:wght@700&family=Poppins:wght@300&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/QR_Code.css">
</head>

<body>
    <div class="main">
        <div class="bigBox">
            {{>Sidebar}}
            <!-- -------------- Start of main ---------------- -->
            <main>
                <div class="boxi">
                    <p>This is Your Resturant QR Code</p>
                    <!-- <input type="text" placeholder="Text or URL" id="qrText"> -->
                    <canvas id="qrCode" aria-label="Restaurant menu QR code"></canvas>
                    <a id="qrTargetLink" class="qr-link" href="/UserMenu" target="_blank" rel="noopener"></a>
                    <p id="qrStatus" class="qr-status"></p>
                    <button type="button" id="generateQrButton">Generate QR Code</button>
                </div>
            </main>
            
            <!-- ------------ End of Main --------------- -->
            
        </div>
    </div>
    <script src="/vendor/qrious/qrious.min.js"></script>
    <script>
        const getMenuUrl = () => new URL('/UserMenu', window.location.origin).href;

        window.generateQRCode = () => {
            const qrText = getMenuUrl();
            const canvas = document.getElementById('qrCode');
            const qrTargetLink = document.getElementById('qrTargetLink');
            const qrStatus = document.getElementById('qrStatus');

            qrTargetLink.href = qrText;
            qrTargetLink.textContent = qrText;

            if (typeof QRious === 'undefined') {
                qrStatus.textContent = 'QR generator failed to load.';
                return;
            }

            new QRious({
                element: canvas,
                size: 220,
                value: qrText,
                level: 'H'
            });
            qrStatus.textContent = 'QR Code ready.';
        };

        document.getElementById('generateQrButton').addEventListener('click', window.generateQRCode);
        window.addEventListener('load', window.generateQRCode);
    </script>
</body>

</html>
