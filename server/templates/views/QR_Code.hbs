<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Table QR Codes</title>
    <link rel="stylesheet" href="/css/homepage.css">
    <script src="https://kit.fontawesome.com/ce75bd9e29.js" crossorigin="anonymous"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Poppins:wght@500;600&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/QR_Code.css">
</head>

<body>
    <div class="main">
        <div class="bigBox">
            {{>Sidebar}}
            <main class="qr-page">
                <section class="qr-header">
                    <div>
                        <p class="eyebrow">Table ordering</p>
                        <h1>QR code generator</h1>
                    </div>
                    <button type="button" class="print-button" onclick="window.print()">
                        <i class="fa-solid fa-print"></i>
                        Print
                    </button>
                </section>

                <section class="counter-qr-panel">
                    <div class="qr-copy">
                        <p class="eyebrow">Comptoir</p>
                        <h2>General QR</h2>
                        <p>Client scans this QR, then chooses the table from the menu.</p>
                        <a id="counterQrLink" class="qr-url" href="/UserMenu?mode=counter" target="_blank"
                            rel="noopener"></a>
                    </div>
                    <div class="qr-preview">
                        <canvas id="counterQrCode" aria-label="General counter QR code"></canvas>
                        <button type="button" class="download-button" data-canvas="counterQrCode"
                            data-name="kaffa-counter-qr.png">
                            <i class="fa-solid fa-download"></i>
                            Download
                        </button>
                    </div>
                </section>

                <section class="table-qr-section">
                    <div class="section-title">
                        <div>
                            <p class="eyebrow">Tables</p>
                            <h2>One QR per table</h2>
                        </div>
                        <span>{{tableCount}} tables</span>
                    </div>

                    <div class="qr-grid">
                        {{#each tables}}
                        <article class="table-qr-card" data-table-card="{{number}}">
                            <div class="card-heading">
                                <div>
                                    <h3>Table {{number}}</h3>
                                    <span>{{zone}} - {{seats}} seats</span>
                                </div>
                                <strong>T{{number}}</strong>
                            </div>
                            <canvas id="tableQr{{number}}" class="table-qr-canvas" data-table-qr="{{number}}"
                                aria-label="Table {{number}} QR code"></canvas>
                            <a class="qr-url table-qr-link" href="/UserMenu?table={{number}}" target="_blank"
                                rel="noopener"></a>
                            <button type="button" class="download-button" data-canvas="tableQr{{number}}"
                                data-name="kaffa-table-{{number}}-qr.png">
                                <i class="fa-solid fa-download"></i>
                                Download
                            </button>
                        </article>
                        {{/each}}
                    </div>
                </section>

                <p id="qrStatus" class="qr-status" role="status" aria-live="polite"></p>
            </main>
        </div>
    </div>

    <script src="/vendor/qrious/qrious.min.js"></script>
    <script>
        const qrStatus = document.getElementById('qrStatus');

        function buildMenuUrl(tableNumber) {
            const url = new URL('/UserMenu', window.location.origin);

            if (tableNumber) {
                url.searchParams.set('table', tableNumber);
            } else {
                url.searchParams.set('mode', 'counter');
            }

            return url.href;
        }

        function renderQr(canvas, value, size) {
            return new QRious({
                element: canvas,
                size,
                value,
                level: 'H',
            });
        }

        function downloadCanvas(canvasId, fileName) {
            const canvas = document.getElementById(canvasId);

            if (!canvas) {
                return;
            }

            const link = document.createElement('a');
            link.href = canvas.toDataURL('image/png');
            link.download = fileName;
            link.click();
        }

        function generateAllQrs() {
            if (typeof QRious === 'undefined') {
                qrStatus.textContent = 'QR generator failed to load.';
                return;
            }

            const counterUrl = buildMenuUrl();
            const counterCanvas = document.getElementById('counterQrCode');
            const counterLink = document.getElementById('counterQrLink');
            counterLink.href = counterUrl;
            counterLink.textContent = counterUrl;
            renderQr(counterCanvas, counterUrl, 240);

            document.querySelectorAll('[data-table-qr]').forEach((canvas) => {
                const tableNumber = canvas.dataset.tableQr;
                const tableUrl = buildMenuUrl(tableNumber);
                const card = canvas.closest('.table-qr-card');
                const link = card.querySelector('.table-qr-link');

                link.href = tableUrl;
                link.textContent = tableUrl;
                renderQr(canvas, tableUrl, 180);
            });

            qrStatus.textContent = 'QR codes ready.';
        }

        document.querySelectorAll('.download-button').forEach((button) => {
            button.addEventListener('click', () => {
                downloadCanvas(button.dataset.canvas, button.dataset.name);
            });
        });

        window.addEventListener('load', generateAllQrs);
    </script>
</body>

</html>
