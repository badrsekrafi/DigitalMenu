<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quick Dine_Delight</title>
    <link rel="stylesheet" href="/css/Menu_Dishes.css">
    <script src="https://kit.fontawesome.com/ce75bd9e29.js" crossorigin="anonymous"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@1&family=Inter:wght@400;500;700&family=Lora:wght@700&family=Poppins:wght@300&display=swap"
        rel="stylesheet">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
</head>

<body>
    <div class="main">
        <div class="bigBox">
            {{>Sidebar}}
            <!-- -------------- Start of main ---------------- -->
            <main class="boxes">
                <section class="upperbox">
                    <div class="upperbox-text">
                        <p class="eyebrow">Inventory</p>
                        <h1>Menu Items</h1>
                    </div>
                    <a class="upperbox-btn" href="/Menu_Dishes_add">
                        <i class="fa-solid fa-plus"></i>
                        <span>Add New Item</span>
                    </a>
                </section>
                <section class="lowerbox">
                    <div class="list-heading">
                        <div>
                            <p class="eyebrow">Products</p>
                            <h2>Menu Items List</h2>
                        </div>
                        <span id="menuItemCount">{{itemCount}} items</span>
                    </div>
                    <div class="lowerbox-table" aria-label="Menu items table">
                        {{#if hasMenuItems}}
                        <table>
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Description</th>
                                    <th>Price</th>
                                    <th>Size</th>
                                    <th>Category</th>
                                    <th>Image</th>
                                    <th>Edit</th>
                                    <th>Delete</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#each MenuItems}}
                                <tr data-id="{{this._id}}" id="Menu_Dishes-{{this._id}}">
                                    <td class="name-cell" data-label="Name">
                                        <span class="cell-text strong-text">{{this.title}}</span>
                                    </td>
                                    <td class="description-cell" data-label="Description">
                                        <span class="cell-text">{{this.description}}</span>
                                    </td>
                                    <td class="price-cell" data-label="Price">
                                        <span class="price-pill">{{this.price}} DNT</span>
                                    </td>
                                    <td class="size-cell" data-label="Size">
                                        <span class="cell-text">{{#if this.size}}{{this.size}}{{else}}-{{/if}}</span>
                                    </td>
                                    <td class="category-cell" data-label="Category">
                                        <span class="category-pill">{{#if this.category}}{{this.category}}{{else}}No category{{/if}}</span>
                                    </td>
                                    <td class="image-cell" data-label="Image">
                                        <img src="{{this.imageUrl}}" alt="{{this.title}}" loading="lazy">
                                    </td>
                                    <td class="edit_column action-cell" data-label="Edit">
                                        <a class="icon-action edit-action" href="/Menu_Dishes_add?id={{this._id}}"
                                            aria-label="Edit {{this.title}}">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </a>
                                    </td>
                                    <td class="delete_column action-cell" data-label="Delete">
                                        <button class="icon-action delete-action" type="button"
                                            onclick="confirmDelete('{{this._id}}')" aria-label="Delete {{this.title}}">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                                {{/each}}
                            </tbody>
                        </table>
                        {{else}}
                        <div class="empty-state">
                            <i class="fa-solid fa-utensils"></i>
                            <p>No menu items yet.</p>
                        </div>
                        {{/if}}
                    </div>
                </section>
                <div id="successPopup" class="popup">
                    <div class="popup_content">
                        <p><i class="fa-solid fa-check"></i>Item deleted successfully!</p>
                    </div>
                </div>
            </main>

            <!-- ------------ End of Main --------------- -->

        </div>
    </div>
    <script>

        function confirmDelete(id) {
            if (confirm('Are you sure you want to delete this Item?')) {
                deleteItem(id);
            }
        }

        function updateItemCount() {
            const countLabel = document.getElementById('menuItemCount');
            const count = document.querySelectorAll('.lowerbox-table tbody tr').length;

            if (countLabel) {
                countLabel.textContent = `${count} ${count === 1 ? 'item' : 'items'}`;
            }
        }

        async function deleteItem(id) {
            try {
                const response = await fetch(`/deleteMenuItem/${encodeURIComponent(id)}`, {
                    method: 'DELETE',
                    headers: {
                        'Accept': 'application/json',
                    },
                });

                if (!response.ok) {
                    throw new Error('Request failed');
                }

                const rowToDelete = document.querySelector(`#Menu_Dishes-${id}`);
                if (rowToDelete) {
                    rowToDelete.remove();
                    updateItemCount();
                    $('#successPopup').fadeIn();
                    setTimeout(function () {
                        $('#successPopup').fadeOut();
                    }, 3000);
                }
            } catch (error) {
                alert('Failed to delete Item. Please try again later!');
            }
        }
        $(document).ready(function () {
            // Hide the popup when clicking anywhere on the window
            $(window).click(function () {
                $('#successPopup').fadeOut();
            });
        });

    </script>
</body>

</html>
