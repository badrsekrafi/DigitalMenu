<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/UserMenu.css">
    <!-- font:Notosnas -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP&display=swap">
    <!-- icons:font awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css">
    <title>Quick Dine_Delight</title>
    <script src="https://kit.fontawesome.com/ce75bd9e29.js" crossorigin="anonymous"></script>


</head>

<body>
    <!-- header -->
    <input type="checkbox" id="cart">
    <label for="cart" class="label-cart"><span class="fas fa-shopping-cart"></span></label>
    <button class="login-btn {{#if menuUser}}is-authenticated{{/if}}" id="loginButton">
        {{#if menuUser}}
        <a href="/UserMenu_logout" id="menuLogoutLink">{{menuUser.username}}</a>
        {{else}}
        <a href="/UserMenu_loginpage" id="menuLoginLink">Login</a>
        {{/if}}
    </button>
    <h3 class="logo"><span class="logo-text">Kaffa Menu</span></h3>
    <div class="search-bar">
        <span class="fas fa-search"></span>
        <input type="text" placeholder="Search">
    </div>

    <!-- main dashbaord -->
    <div class="dashboard">
        {{#if latestImage}}
        <div class="dashboard-banner">
            {{#if latestImage}}
            <img src="{{latestImage.base64Image}}" alt="{{latestImage.title}}">
            {{/if}}
        </div>
        {{/if}}

        <div class="table-context" id="tableContext" hidden>
            <div>
                <p id="tableContextKicker">Commande sur place</p>
                <strong id="tableContextLabel">Choose your table</strong>
            </div>
            <label id="tableSelectorWrap" for="userMenuTableSelect">
                Table
                <select id="userMenuTableSelect">
                    <option value="">Choose table</option>
                    {{#each tables}}
                    <option value="{{number}}">Table {{number}} - {{seats}} seats</option>
                    {{/each}}
                </select>
            </label>
        </div>

        <div class="menu-heading">
            <div>
                <p class="menu-kicker">Digital menu</p>
                <h2>Choose by category</h2>
            </div>
            <span>{{totalItems}} items</span>
        </div>

        <div class="dashboard-menu" aria-label="Menu categories">
            <a class="menu-item active" href="#all-products" data-category="all">All <span>{{totalItems}}</span></a>
            {{#each categorySections}}
            <a class="menu-item" href="#{{this.sectionId}}" data-category="{{this.title}}">{{this.title}} <span>{{this.itemCount}}</span></a>
            {{/each}}
        </div>

        <p class="no-results" hidden>No menu items match your search.</p>

        <div class="menu-sections" id="all-products">
            {{#each categorySections}}
            <section class="menu-category-section" id="{{this.sectionId}}" data-category="{{this.title}}">
                <div class="category-heading">
                    <h3>{{this.title}}</h3>
                    <span>{{this.itemCount}} items</span>
                </div>
                <div class="dashboard-content">
                    {{#each this.items}}
                    <div class="dashboard-card" data-category="{{this.category}}" data-title="{{this.title}}">
                        <img src="{{this.imageUrl}}" alt="{{this.title}}" class="card-image">
                        <div class="card-detail">
                            <h4>{{this.title}}<span>{{this.price}} DNT</span></h4>
                            <p>{{this.description}}</p>
                            <p class="card-time">{{this.category}}</p>
                        </div>
                        <button class="add-to-cart-btn" data-name="{{this.title}}" data-price="{{this.price}}"
                            data-img="{{this.imageUrl}}">Add to Cart</button>
                    </div>
                    {{/each}}
                </div>
            </section>
            {{/each}}
        </div>
    </div>

    <!-- order dashboard -->
    <div class="dashboard-order" id="dashboard-order">
        <div class="dashboard-text">
            <h3>Order Menu</h3>
            <div class="order-address">
                <p>Cafe Location</p>
                <h4>Marina 4180 Houmt Souk Djerba, Tunis</h4>
            </div>
            <div class="order-time">
                <span class="fas fa-clock"></span> 30 mins <span class="fas fa-map-marker-alt"></span> 2 Km
            </div>

            <div class="cart-wrapper">
                <h3>Your Cart</h3>
                <div class="order-items-container">
                    <!-- Selected items will be displayed here -->
                </div>
                <button id="close-cart">Close Cart</button>
            </div>

            <hr class="divider">
            <div class="order-total">
                <p>Subtotal <span class="subtotal">0 DNT</span></p>
                <p>Delivery Fee <span>0 DNT</span></p>
                <hr class="divider">
                <p>Total<span id="grand-total">0.00 DNT</span></p>
            </div>
            <a href="/Order_Details" class="checkout" id="checkoutLink">Checkout</a>
            <!-- <button>Checkout</button> -->
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const tableStorageKey = 'kaffaSelectedTableNumber';
            const tableLockedStorageKey = 'kaffaSelectedTableLocked';
            const params = new URLSearchParams(window.location.search);
            const tableContext = document.getElementById('tableContext');
            const tableContextKicker = document.getElementById('tableContextKicker');
            const tableContextLabel = document.getElementById('tableContextLabel');
            const tableSelectorWrap = document.getElementById('tableSelectorWrap');
            const tableSelect = document.getElementById('userMenuTableSelect');
            const checkoutLink = document.getElementById('checkoutLink');
            const loginLink = document.getElementById('menuLoginLink');
            const logoutLink = document.getElementById('menuLogoutLink');
            const currentReturnTo = `${window.location.pathname}${window.location.search}`;

            if (loginLink) {
                loginLink.href = `/UserMenu_loginpage?returnTo=${encodeURIComponent(currentReturnTo)}`;
            }

            if (logoutLink) {
                logoutLink.href = `/UserMenu_logout?returnTo=${encodeURIComponent(currentReturnTo)}`;
            }

            function normalizeTableNumber(value) {
                const tableNumber = Number(value);
                return Number.isInteger(tableNumber) && tableNumber > 0 ? String(tableNumber) : '';
            }

            const urlTable = normalizeTableNumber(params.get('table'));
            const isCounterMode = params.get('mode') === 'counter';

            if (urlTable) {
                localStorage.setItem(tableStorageKey, urlTable);
                localStorage.setItem(tableLockedStorageKey, 'true');
            } else if (isCounterMode) {
                localStorage.removeItem(tableStorageKey);
                localStorage.setItem(tableLockedStorageKey, 'false');
            }

            function getSelectedTable() {
                return normalizeTableNumber(localStorage.getItem(tableStorageKey));
            }

            function isTableLocked() {
                return localStorage.getItem(tableLockedStorageKey) === 'true' && Boolean(getSelectedTable());
            }

            function updateCheckoutLink() {
                const selectedTable = getSelectedTable();
                const url = new URL('/Order_Details', window.location.origin);

                if (selectedTable) {
                    url.searchParams.set('table', selectedTable);
                } else if (isCounterMode) {
                    url.searchParams.set('mode', 'counter');
                }

                checkoutLink.href = `${url.pathname}${url.search}`;
            }

            function renderTableContext() {
                const selectedTable = getSelectedTable();
                const locked = isTableLocked();
                const shouldShowContext = Boolean(selectedTable || urlTable || isCounterMode);

                tableContext.hidden = !shouldShowContext;
                tableContext.classList.toggle('is-locked', locked);
                tableSelectorWrap.hidden = locked;

                if (selectedTable) {
                    tableSelect.value = selectedTable;
                    tableContextKicker.textContent = locked ? 'Table QR scanned' : 'Commande sur place';
                    tableContextLabel.textContent = `Table ${selectedTable}`;
                } else {
                    tableSelect.value = '';
                    tableContextKicker.textContent = 'Comptoir QR';
                    tableContextLabel.textContent = 'Choose your table';
                }

                updateCheckoutLink();
            }

            tableSelect.addEventListener('change', () => {
                const selectedTable = normalizeTableNumber(tableSelect.value);

                if (selectedTable) {
                    localStorage.setItem(tableStorageKey, selectedTable);
                    localStorage.setItem(tableLockedStorageKey, 'false');
                } else {
                    localStorage.removeItem(tableStorageKey);
                    localStorage.setItem(tableLockedStorageKey, 'false');
                }

                renderTableContext();
            });

            renderTableContext();
        });
    </script>
    <script src="/javascript/MenuFitering.js"></script>
    <script src="/javascript/UserMenu_Cart.js"></script>
</body>

</html>
