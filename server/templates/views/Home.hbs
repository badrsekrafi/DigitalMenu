<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Menu</title>
    <link rel="stylesheet" href="/css/homepage.css">
    <script src="https://kit.fontawesome.com/ce75bd9e29.js" crossorigin="anonymous"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@1&family=Inter:wght@400;500;700;800&family=Lora:wght@700&family=Poppins:wght@300&display=swap"
        rel="stylesheet">
</head>

<body>
    <div class="main">
        <div class="bigBox">
            {{>Sidebar}}

            <main class="boxes dashboard-page">
                <section class="upperbox dashboard-hero">
                    <div class="upperbox-text">
                        <p class="eyebrow">Overview</p>
                        <h1>Dashboard</h1>
                        <p class="welcome-text">Hey, <strong>{{adminName}}</strong></p>
                    </div>

                    <div class="dashboard-tools">
                        <label class="date-pill" for="date">
                            <i class="fa-regular fa-calendar"></i>
                            <input type="date" id="date" class="unstyled">
                        </label>
                        <div class="admin-chip">
                            <div>
                                <span>Admin</span>
                                <strong>{{adminName}}</strong>
                            </div>
                            <img src="/images/Admin_image.png" alt="Admin profile">
                        </div>
                    </div>
                </section>

                <section class="insights" aria-label="Dashboard stats">
                    <article class="stat-card sales">
                        <i class="fa fa-line-chart"></i>
                        <div>
                            <h2 id="menuItemCount">0</h2>
                            <p>Menu Items</p>
                        </div>
                    </article>

                    <article class="stat-card items">
                        <i class="fa fa-gift"></i>
                        <div>
                            <h2 id="categoryCount">0</h2>
                            <p>Categories</p>
                        </div>
                    </article>

                    <article class="stat-card orders">
                        <i class="fa fa-shopping-basket"></i>
                        <div>
                            <h2 id="orderCount">0</h2>
                            <p>Orders</p>
                        </div>
                    </article>
                </section>

                <section class="dashboard-grid">
                    <section class="lowerbox recent-orders">
                        <div class="list-heading">
                            <div>
                                <p class="eyebrow">Latest activity</p>
                                <h2>Recent Orders</h2>
                            </div>
                            <a class="view-all-link" href="/Orders">
                                <i class="fa-solid fa-arrow-up-right-from-square"></i>
                                Show All
                            </a>
                        </div>

                        <div class="lowerbox-table" aria-label="Recent orders table">
                            {{#if hasOrders}}
                            <table>
                                <thead>
                                    <tr>
                                        <th>Table</th>
                                        <th>Name</th>
                                        <th>Items</th>
                                        <th>Amount</th>
                                        <th>View</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {{#each orders}}
                                    <tr>
                                        <td data-label="Table">
                                            <span class="cell-text strong-text">
                                                {{#if TableNumber}}Table {{TableNumber}}{{else}}Reservation{{/if}}
                                            </span>
                                        </td>
                                        <td data-label="Name">
                                            <span class="cell-text">{{name}}</span>
                                        </td>
                                        <td data-label="Items">
                                            <span class="cell-text">
                                                {{#each items}}
                                                {{this.itemName}}
                                                {{#unless @last}}, {{/unless}}
                                                {{/each}}
                                            </span>
                                        </td>
                                        <td data-label="Amount">
                                            <span class="cell-text strong-text">{{totalPrice}} DNT</span>
                                        </td>
                                        <td data-label="View" class="action-cell">
                                            <a class="icon-action" href="/Orders" aria-label="View orders">
                                                <i class="fa-solid fa-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                    {{/each}}
                                </tbody>
                            </table>
                            {{else}}
                            <div class="empty-state">
                                <i class="fa-solid fa-receipt"></i>
                                <p>No orders yet.</p>
                            </div>
                            {{/if}}
                        </div>
                    </section>

                    <section class="lowerbox dashboard-qr-card">
                        <div class="list-heading">
                            <div>
                                <p class="eyebrow">Quick access</p>
                                <h2>General QR</h2>
                            </div>
                            <a class="view-all-link" href="/QR_Code">
                                <i class="fa-solid fa-qrcode"></i>
                                QR Page
                            </a>
                        </div>
                        <div class="dashboard-qr-frame">
                            <div class="updates12"></div>
                        </div>
                    </section>
                </section>
            </main>
        </div>
    </div>

    <script src="/vendor/qrious/qrious.min.js"></script>
    <script>
        document.getElementById('date').valueAsDate = new Date();

        const updateMenuItemCount = (count) => {
            const menuItemCountElement = document.getElementById('menuItemCount');
            if (menuItemCountElement) {
                menuItemCountElement.innerText = count;
            }
        };

        fetch('/getMenuItemCount')
            .then(response => response.json())
            .then(data => updateMenuItemCount(data.menuItemCount))
            .catch(error => {
                console.error('Error fetching menu item count:', error);
                updateMenuItemCount(0);
            });

        const updateCategoryCount = (count) => {
            const categoryCountElement = document.getElementById('categoryCount');
            if (categoryCountElement) {
                categoryCountElement.innerText = count;
            }
        };

        fetch('/getCategoryCount')
            .then(response => response.json())
            .then(data => updateCategoryCount(data.categoryCount))
            .catch(error => console.error('Error fetching category count:', error));

        const updateOrderCount = (count) => {
            const orderCountElement = document.getElementById('orderCount');
            if (orderCountElement) {
                orderCountElement.innerText = count;
            }
        };

        fetch('/getorderCount')
            .then(response => response.json())
            .then(data => updateOrderCount(data.OrderCount))
            .catch(error => console.error('Error fetching Order count:', error));

        function generateQRCode() {
            if (typeof QRious === 'undefined') {
                return;
            }

            const qrText = new URL('/UserMenu', window.location.origin).href;
            const canvas = document.createElement('canvas');
            new QRious({
                element: canvas,
                size: 184,
                level: 'H',
                value: qrText,
            });

            const qrSlot = document.querySelector('.updates12');
            qrSlot.innerHTML = '';
            qrSlot.appendChild(canvas);
        }

        window.addEventListener('load', generateQRCode);
    </script>
    <script src="/javascript/index.js"></script>
</body>

</html>
