<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quick Dine_Delight</title>
    <link rel="stylesheet" href="/css/Orders.css">
    <script src="https://kit.fontawesome.com/ce75bd9e29.js" crossorigin="anonymous"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@1&family=Inter:wght@400;500;700&family=Lora:wght@700&family=Poppins:wght@300&display=swap"
        rel="stylesheet">
</head>

<body>
    <div class="main">
        <div class="bigBox">
            {{>Sidebar}}
            <main class="boxes">
                <div class="lowerbox">
                    <h4>Orders</h4>
                    <div class="lowerbox-table">
                        <table>
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Date</th>
                                    <th>Name</th>
                                    <th>Phone Number</th>
                                    <th>Email</th>
                                    <th>Type</th>
                                    <th>Seats</th>
                                    <th>Table Number</th>
                                    <th>Reservation</th>
                                    <th>Items</th>
                                    <th>Amount</th>
                                    <th>Status</th>
                                    <th>View</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#each orders}}
                                <tr>
                                    <td data-label="ID">{{orderIdDisplay}}</td>
                                    <td data-label="Date">{{createdAtDisplay}}</td>
                                    <td data-label="Name">{{name}}</td>
                                    <td data-label="Phone Number">{{PhoneNumber}}</td>
                                    <td data-label="Email">{{email}}</td>
                                    <td data-label="Type"><span class="order-type {{serviceTypeClass}}">{{serviceTypeLabel}}</span></td>
                                    <td data-label="Seats">{{seatCount}}</td>
                                    <td data-label="Table Number">{{tableDisplay}}</td>
                                    <td data-label="Reservation">{{reservationLabel}}</td>
                                    <td data-label="Items" class="items-cell">
                                        <div class="item-status-list">
                                        {{#each items}}
                                            <div class="item-status-row" data-order-id="{{orderId}}" data-item-index="{{itemIndex}}">
                                                <span class="item-status-name">{{this.itemName}}</span>
                                                <span class="item-status-pill {{statusClass}}">{{statusLabel}}</span>
                                                <select class="item-status-select" data-order-id="{{orderId}}"
                                                    data-item-index="{{itemIndex}}" data-current-status="{{status}}"
                                                    aria-label="Status for {{this.itemName}}">
                                                    {{#each statusOptions}}
                                                    <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                                                    {{/each}}
                                                </select>
                                            </div>
                                        {{/each}}
                                        </div>
                                    </td>
                                    <td data-label="Amount">{{totalPriceDisplay}} DNT</td>
                                    <td data-label="Status"><span class="order-status">{{statusLabel}}</span></td>
                                    <td data-label="View">
                                        <button type="button" class="details-button">Afficher tous</button>
                                    </td>
                                </tr>
                                {{/each}}
                            </tbody>
                        </table>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <div class="order-modal" id="orderDetailsModal" hidden>
        <div class="modal-backdrop" data-close-modal></div>
        <section class="modal-panel" role="dialog" aria-modal="true" aria-labelledby="orderDetailsTitle">
            <div class="modal-header">
                <div>
                    <p>Notification</p>
                    <h3 id="orderDetailsTitle">Coordonnees commande</h3>
                </div>
                <button type="button" class="modal-close" data-close-modal aria-label="Close details">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="modal-content" id="orderDetailsContent"></div>
        </section>
    </div>

    <script>
        const orderDetailsModal = document.getElementById('orderDetailsModal');
        const orderDetailsContent = document.getElementById('orderDetailsContent');

        function closeOrderModal() {
            orderDetailsModal.hidden = true;
            document.body.classList.remove('modal-open');
        }

        function escapeHtml(value) {
            return String(value)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        }

        document.querySelectorAll('.details-button').forEach((button) => {
            button.addEventListener('click', () => {
                const row = button.closest('tr');
                const details = Array.from(row.querySelectorAll('td[data-label]'))
                    .filter((cell) => cell.dataset.label !== 'View')
                    .map((cell) => ({
                        label: cell.dataset.label,
                        value: cell.innerText.trim() || '-',
                    }));

                orderDetailsContent.innerHTML = details.map((detail) => `
                    <div class="detail-line">
                        <span>${escapeHtml(detail.label)}</span>
                        <strong>${escapeHtml(detail.value)}</strong>
                    </div>
                `).join('');

                orderDetailsModal.hidden = false;
                document.body.classList.add('modal-open');
            });
        });

        document.querySelectorAll('[data-close-modal]').forEach((button) => {
            button.addEventListener('click', closeOrderModal);
        });

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape' && !orderDetailsModal.hidden) {
                closeOrderModal();
            }
        });

        document.querySelectorAll('.item-status-select').forEach((select) => {
            select.addEventListener('change', async () => {
                const previousStatus = select.dataset.currentStatus;
                const row = select.closest('.item-status-row');
                const pill = row.querySelector('.item-status-pill');
                const selectedOption = select.options[select.selectedIndex];

                select.disabled = true;

                try {
                    const response = await fetch(`/orders/${encodeURIComponent(select.dataset.orderId)}/items/${encodeURIComponent(select.dataset.itemIndex)}/status`, {
                        method: 'PATCH',
                        headers: {
                            'Content-Type': 'application/json',
                            'Accept': 'application/json',
                        },
                        body: JSON.stringify({ status: select.value }),
                    });
                    const data = await response.json();

                    if (!response.ok || !data.success) {
                        throw new Error(data.error || 'Could not update status.');
                    }

                    select.dataset.currentStatus = data.item.status;
                    pill.className = `item-status-pill ${data.item.statusClass}`;
                    pill.textContent = data.item.statusLabel;
                } catch (error) {
                    select.value = previousStatus;
                    alert(error.message || 'Could not update status.');
                } finally {
                    select.disabled = false;
                }
            });
        });
    </script>
</body>

</html>
