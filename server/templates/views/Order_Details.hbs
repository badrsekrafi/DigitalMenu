<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Checkout - Kaffa Menu</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/Order_Details.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@10"></script>
</head>

<body>
    <section class="order" id="order">
        <div class="checkout-shell">
            <div class="checkout-panel">
                <header class="checkout-hero">
                    <p class="eyebrow">Checkout</p>
                    <h1>Complete your order</h1>
                    <p>Confirm your details, choose sur place or reservation, then send the order to Kaffa.</p>
                </header>

                <form action="" method="post" id="orderForm" class="checkout-form">
                    {{#if checkoutUser.isLoggedIn}}
                    <div class="checkout-account">
                        <span>Signed in account</span>
                        <strong>{{checkoutUser.name}}</strong>
                    </div>
                    {{/if}}

                    <div class="form-section">
                        <div class="section-title">
                            <span>1</span>
                            <div>
                                <h2>Service</h2>
                                <p>Choose whether this is a table order or a reservation.</p>
                            </div>
                        </div>

                        <div class="service-choice" aria-label="Choose checkout type">
                            <label class="service-card">
                                <input type="radio" name="serviceType" value="dine-in" checked>
                                <span>Commande sur place</span>
                                <small>For clients already sitting in the cafe.</small>
                            </label>
                            <label class="service-card">
                                <input type="radio" name="serviceType" value="reservation">
                                <span>Reservation</span>
                                <small>Choose the exact date and time to come.</small>
                            </label>
                        </div>
                    </div>

                    <div class="form-section">
                        <div class="section-title">
                            <span>2</span>
                            <div>
                                <h2>Client details</h2>
                                <p>Logged in clients keep their saved contact details.</p>
                            </div>
                        </div>

                        <div class="inputBox">
                            <div class="input">
                                <label for="name">Your Name</label>
                                <input type="text" id="name" name="name" placeholder="Enter Your Name"
                                    value="{{checkoutUser.name}}" {{#if checkoutUser.isLoggedIn}}readonly{{/if}} required>
                            </div>
                            <div class="input">
                                <label for="number">Your Phone Number</label>
                                <input type="tel" id="number" name="PhoneNumber" placeholder="Enter Your Phone Number"
                                    value="{{checkoutUser.phone}}" {{#if checkoutUser.isLoggedIn}}readonly{{/if}} required>
                            </div>
                        </div>

                        <div class="inputBox">
                            <div class="input">
                                <label for="email">Your Email</label>
                                <input type="email" id="email" name="email" placeholder="Enter Your Email"
                                    value="{{checkoutUser.email}}" {{#if checkoutUser.isLoggedIn}}readonly{{/if}}>
                            </div>
                            <div class="input">
                                <label for="seatCount">Number of seats / people</label>
                                <input type="number" id="seatCount" name="seatCount" placeholder="How many people?" min="1" value="1" required>
                            </div>
                        </div>
                    </div>

                    <div class="form-section">
                        <div class="section-title">
                            <span>3</span>
                            <div>
                                <h2>Table or reservation time</h2>
                                <p>Table QR orders keep the scanned table locked.</p>
                            </div>
                        </div>

                        <div class="inputBox">
                            <div class="input" id="tableNumberField">
                                <label for="TableNumber">Your Table Number</label>
                                <select id="TableNumber" name="TableNumber" required>
                                    <option value="">Choose table</option>
                                    {{#each tables}}
                                    <option value="{{number}}">Table {{number}} - {{seats}} seats</option>
                                    {{/each}}
                                </select>
                                <p class="table-lock-note" id="tableLockNote" hidden>
                                    Commande sur place for <strong id="lockedTableLabel"></strong>
                                </p>
                            </div>
                        </div>

                        <div class="inputBox reservation-fields" id="reservationFields" hidden>
                            <div class="input">
                                <label for="reservationDate">Reservation Date</label>
                                <input type="date" id="reservationDate" name="reservationDate">
                            </div>
                            <div class="input">
                                <label for="reservationTime">Reservation Time</label>
                                <input type="time" id="reservationTime" name="reservationTime">
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn">Send order</button>
                </form>
            </div>

            <aside class="checkout-summary" aria-label="Order summary">
                <div class="summary-card">
                    <div class="summary-title">
                        <div>
                            <p class="eyebrow">Your cart</p>
                            <h2>Order summary</h2>
                        </div>
                        <span class="summary-badge">DNT</span>
                    </div>

                    <div class="order-items-container">
                        {{#each cart.items}}
                        <div class="cart-item">
                            <img src="{{this.img}}" alt="{{this.name}}" class="cart-item-image">
                            <span class="item-name">{{this.name}}</span>
                            <span class="item-price">{{formatCurrency this.price}} DNT</span>
                            <button type="button" class="remove-item-button" onclick="removeItem('{{this.name}}')">Remove</button>
                        </div>
                        {{/each}}
                    </div>

                    <div class="summary-total">
                        <span>Total</span>
                        <strong id="total-price-container">0.00 DNT</strong>
                    </div>
                </div>
            </aside>
        </div>
    </section>

    <script>
        function getCartFromLocalStorage() {
            const cartData = localStorage.getItem("cart");
            return cartData ? JSON.parse(cartData) : { items: [], subtotal: 0 };
        }

        function normalizeCart(cart) {
            const items = Array.isArray(cart.items) ? cart.items : [];
            const subtotal = items.reduce((sum, item) => sum + Number(item.price || 0), 0);
            return { items, subtotal, total: subtotal };
        }

        function getSelectedServiceType() {
            const selected = document.querySelector('input[name="serviceType"]:checked');
            return selected ? selected.value : 'dine-in';
        }

        const tableStorageKey = 'kaffaSelectedTableNumber';
        const tableLockedStorageKey = 'kaffaSelectedTableLocked';

        function normalizeTableNumber(value) {
            const tableNumber = Number(value);
            return Number.isInteger(tableNumber) && tableNumber > 0 ? String(tableNumber) : '';
        }

        function readCheckoutTableContext() {
            const params = new URLSearchParams(window.location.search);
            const urlTable = normalizeTableNumber(params.get('table'));
            const isCounterMode = params.get('mode') === 'counter';

            if (urlTable) {
                localStorage.setItem(tableStorageKey, urlTable);
                localStorage.setItem(tableLockedStorageKey, 'true');
            } else if (isCounterMode) {
                localStorage.setItem(tableLockedStorageKey, 'false');
            }

            const storedTable = normalizeTableNumber(localStorage.getItem(tableStorageKey));
            const locked = localStorage.getItem(tableLockedStorageKey) === 'true' && Boolean(storedTable);

            return {
                tableNumber: storedTable,
                locked,
                isCounterMode,
            };
        }

        function syncCheckoutFields() {
            const isReservation = getSelectedServiceType() === 'reservation';
            const reservationFields = document.getElementById('reservationFields');
            const reservationDateInput = document.getElementById('reservationDate');
            const reservationTimeInput = document.getElementById('reservationTime');
            const tableNumberField = document.getElementById('tableNumberField');
            const tableNumberInput = document.getElementById('TableNumber');
            const tableLockNote = document.getElementById('tableLockNote');
            const lockedTableLabel = document.getElementById('lockedTableLabel');
            const tableContext = readCheckoutTableContext();

            reservationFields.hidden = !isReservation;
            reservationDateInput.required = isReservation;
            reservationTimeInput.required = isReservation;
            tableNumberField.classList.toggle('is-hidden', isReservation);
            tableNumberInput.required = !isReservation;
            tableNumberField.classList.toggle('is-locked', !isReservation && tableContext.locked);
            tableLockNote.hidden = isReservation || !tableContext.locked;

            if (isReservation) {
                tableNumberInput.required = false;
            } else {
                if (tableContext.tableNumber) {
                    tableNumberInput.value = tableContext.tableNumber;
                    lockedTableLabel.textContent = `Table ${tableContext.tableNumber}`;
                }
                reservationDateInput.value = '';
                reservationTimeInput.value = '';
            }
        }

        function saveCart(cart) {
            localStorage.setItem("cart", JSON.stringify(normalizeCart(cart)));
        }

        function removeItemFromCart(itemToRemove) {
            const cart = normalizeCart(getCartFromLocalStorage());
            const itemIndex = cart.items.findIndex(item => item.name === itemToRemove.name && Number(item.price) === Number(itemToRemove.price));

            if (itemIndex > -1) {
                cart.items.splice(itemIndex, 1);
                saveCart(cart);
                renderCartSummary();
            }
        }

        function renderCartSummary() {
            const cart = normalizeCart(getCartFromLocalStorage());
            const orderItemsContainer = document.querySelector(".order-items-container");
            const totalPriceContainer = document.getElementById("total-price-container");

            orderItemsContainer.innerHTML = "";

            if (cart.items.length === 0) {
                const emptyState = document.createElement("p");
                emptyState.className = "empty-cart-message";
                emptyState.textContent = "Your cart is empty. Add items from the menu first.";
                orderItemsContainer.appendChild(emptyState);
            }

            cart.items.forEach(item => {
                const itemElement = document.createElement("div");
                itemElement.classList.add("cart-item", "added-food");

                const itemImage = document.createElement("img");
                itemImage.src = item.img;
                itemImage.alt = item.name;
                itemImage.classList.add("cart-item-image", "added-food");

                const itemName = document.createElement("span");
                itemName.textContent = item.name;
                itemName.classList.add("item-name", "added-food");

                const itemPrice = document.createElement("span");
                itemPrice.textContent = `${Number(item.price || 0).toFixed(2)} DNT`;
                itemPrice.classList.add("item-price", "added-food");

                const closeButton = document.createElement("button");
                closeButton.type = "button";
                closeButton.textContent = "Remove";
                closeButton.classList.add("close-food-button");
                closeButton.addEventListener("click", () => {
                    removeItemFromCart(item);
                });

                itemElement.appendChild(itemImage);
                itemElement.appendChild(itemName);
                itemElement.appendChild(itemPrice);
                itemElement.appendChild(closeButton);
                orderItemsContainer.appendChild(itemElement);
            });

            totalPriceContainer.textContent = `${cart.subtotal.toFixed(2)} DNT`;
            saveCart(cart);
        }

        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll('input[name="serviceType"]').forEach(input => {
                input.addEventListener('change', syncCheckoutFields);
            });

            document.getElementById('TableNumber').addEventListener('change', (event) => {
                const tableNumber = normalizeTableNumber(event.target.value);

                if (tableNumber) {
                    localStorage.setItem(tableStorageKey, tableNumber);
                    localStorage.setItem(tableLockedStorageKey, 'false');
                } else {
                    localStorage.removeItem(tableStorageKey);
                    localStorage.setItem(tableLockedStorageKey, 'false');
                }
            });

            syncCheckoutFields();
            renderCartSummary();

            const orderForm = document.getElementById('orderForm');

            orderForm.addEventListener('submit', async function (event) {
                event.preventDefault();

                const selectedServiceType = getSelectedServiceType();
                const seatCount = Number(document.getElementById('seatCount').value);
                const tableNumber = document.getElementById('TableNumber').value;
                const reservationDate = document.getElementById('reservationDate').value;
                const reservationTime = document.getElementById('reservationTime').value;
                const currentCart = normalizeCart(getCartFromLocalStorage());
                const itemsData = currentCart.items;

                if (itemsData.length === 0) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Cart is empty',
                        text: 'Please add at least one item before sending the order.',
                    });
                    return;
                }

                if (!Number.isInteger(seatCount) || seatCount < 1) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Seats required',
                        text: 'Please enter the number of seats / people.',
                    });
                    return;
                }

                if (selectedServiceType === 'dine-in' && !tableNumber) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Table number required',
                        text: 'Please choose your table for commande sur place.',
                    });
                    return;
                }

                if (selectedServiceType === 'reservation' && (!reservationDate || !reservationTime)) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Reservation date and time required',
                        text: 'Please choose the exact date and time.',
                    });
                    return;
                }

                const items = itemsData.map(item => ({ itemName: item.name }));

                const formData = {
                    name: document.getElementById('name').value,
                    PhoneNumber: document.getElementById('number').value,
                    email: document.getElementById('email').value,
                    serviceType: selectedServiceType,
                    seatCount,
                    TableNumber: selectedServiceType === 'dine-in' ? tableNumber : '',
                    reservationDate: selectedServiceType === 'reservation' ? reservationDate : '',
                    reservationTime: selectedServiceType === 'reservation' ? reservationTime : '',
                    items,
                    totalPrice: currentCart.total,
                };

                try {
                    const response = await fetch('/Order_Details', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify(formData),
                    });

                    if (response.ok) {
                        Swal.fire({
                            icon: 'success',
                            title: selectedServiceType === 'reservation' ? 'Reservation Sent Successfully!' : 'Order Placed Successfully!',
                            showConfirmButton: false,
                            timer: 3000
                        });

                        setTimeout(() => {
                            localStorage.removeItem("cart");
                            const redirectUrl = new URL('/UserMenu', window.location.origin);
                            if (selectedServiceType === 'dine-in' && tableNumber) {
                                redirectUrl.searchParams.set('table', tableNumber);
                            }
                            window.location.href = `${redirectUrl.pathname}${redirectUrl.search}`;
                        }, 1500);
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error Placing Order',
                            text: await response.text() || 'Please try again.',
                        });
                    }
                } catch (error) {
                    console.error('Error submitting order:', error);
                    Swal.fire({
                        icon: 'error',
                        title: 'Connection error',
                        text: 'Please try again.',
                    });
                }
            });
        });

        function removeItem(name) {
            const cart = normalizeCart(getCartFromLocalStorage());
            const itemIndex = cart.items.findIndex(item => item.name === name);

            if (itemIndex > -1) {
                cart.items.splice(itemIndex, 1);
                saveCart(cart);
                renderCartSummary();
            }
        }
    </script>
</body>

</html>
