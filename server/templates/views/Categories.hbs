<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quick Dine_Delight</title>
    <!-- <link rel="stylesheet" href="/css/homepage.css"> -->
    <link rel="stylesheet" href="/css/categories.css">
    <script src="https://kit.fontawesome.com/ce75bd9e29.js" crossorigin="anonymous"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@1&family=Inter:wght@400;500;700&family=Lora:wght@700&family=Poppins:wght@300&display=swap"
        rel="stylesheet">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
</head>

<body>
    <div class="main">
        <div class="bigBox">
            {{>Sidebar}}
            <!-- -------------- Start of main ---------------- -->
            <main class="boxes">
                <section class="upperbox">
                    <div class="upperbox-text">
                        <p class="eyebrow">Inventory</p>
                        <h1>Categories</h1>
                    </div>
                    <a class="upperbox-btn" href="/Categories_add">
                        <i class="fa-solid fa-plus"></i>
                        <span>Add New Category</span>
                    </a>
                </section>
                <section class="lowerbox">
                    <div class="list-heading">
                        <div>
                            <p class="eyebrow">Groups</p>
                            <h2>Category List</h2>
                        </div>
                        <span id="categoryCountLabel">{{categoryCount}} categories</span>
                    </div>
                    <div class="lowerbox-table" aria-label="Categories table">
                        {{#if hasCategories}}
                        <table>
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Description</th>
                                    <th>Edit</th>
                                    <th>Delete</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#each categories}}
                                <tr data-id="{{this._id}}" id="category-{{this._id}}">
                                    <td class="name-cell" data-label="Name">
                                        <span class="cell-text strong-text">{{this.title}}</span>
                                    </td>
                                    <td class="description-cell" data-label="Description">
                                        <span class="cell-text">{{this.description}}</span>
                                    </td>
                                    <td class="action-cell" data-label="Edit">
                                        <a class="icon-action edit-action" href="/Categories_add?id={{this._id}}"
                                            aria-label="Edit {{this.title}}">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </a>
                                    </td>
                                    <td class="action-cell" data-label="Delete">
                                        <button class="icon-action delete-action" type="button"
                                            onclick="confirmDelete('{{this._id}}')" aria-label="Delete {{this.title}}">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                                {{/each}}
                            </tbody>
                        </table>
                        {{else}}
                        <div class="empty-state">
                            <i class="fa-solid fa-layer-group"></i>
                            <p>No categories yet.</p>
                        </div>
                        {{/if}}
                    </div>
                </section>
                <div id="successPopup" class="popup">
                    <div class="popup_content">
                        <p><i class="fa-solid fa-check"></i>Category deleted successfully!</p>
                    </div>
                </div>
            </main>

            <!-- ------------ End of Main --------------- -->

        </div>
    </div>
    <script>

        function confirmDelete(id) {
            if (confirm('Are you sure you want to delete this category?')) {
                deleteCategory(id);
            }
        }

        function updateCategoryCount() {
            const countLabel = document.getElementById('categoryCountLabel');
            const count = document.querySelectorAll('.lowerbox-table tbody tr').length;

            if (countLabel) {
                countLabel.textContent = `${count} ${count === 1 ? 'category' : 'categories'}`;
            }
        }

        async function deleteCategory(id) {
            try {
                const response = await fetch(`/deleteCategory/${encodeURIComponent(id)}`, {
                    method: 'DELETE',
                    headers: {
                        'Accept': 'application/json',
                    },
                });

                const data = await response.json();
                if (!response.ok || !data.success) {
                    throw new Error('Request failed');
                }

                const row = document.querySelector(`tr[data-id="${id}"]`);
                if (row) {
                    row.remove();
                    updateCategoryCount();
                    $('#successPopup').fadeIn();
                }

                setTimeout(function () {
                    $('#successPopup').fadeOut();
                }, 3000);
            } catch (error) {
                alert('Failed to delete category. Please try again later.');
            }
        }

        $(document).ready(function () {
            // Hide the popup when clicking anywhere on the window
            $(window).click(function () {
                $('#successPopup').fadeOut();
            });
        });

    </script>
</body>

</html>
