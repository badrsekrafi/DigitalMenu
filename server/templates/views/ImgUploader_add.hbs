<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cafe Table Map</title>
    <link rel="stylesheet" href="/css/ImgUploader_add.css">
    <script src="https://kit.fontawesome.com/ce75bd9e29.js" crossorigin="anonymous"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Poppins:wght@500;600&display=swap"
        rel="stylesheet">
</head>

<body>
    <div class="main">
        <div class="bigBox">
            {{>Sidebar}}
            <main class="table-map-page">
                <section class="table-map-header">
                    <div>
                        <p class="eyebrow">Cafe floor</p>
                        <h1>Table map</h1>
                    </div>
                    <a class="orders-link" href="/Orders">
                        <i class="fa-solid fa-receipt"></i>
                        Orders
                    </a>
                </section>

                <section class="table-stats" aria-label="Table status summary">
                    <div class="stat-block">
                        <span>Total tables</span>
                        <strong>{{tableStats.totalTables}}</strong>
                    </div>
                    <div class="stat-block is-free">
                        <span>Free</span>
                        <strong>{{tableStats.freeTables}}</strong>
                    </div>
                    <div class="stat-block is-reserved">
                        <span>Reserved</span>
                        <strong>{{tableStats.reservedTables}}</strong>
                    </div>
                    <div class="stat-block">
                        <span>Active orders</span>
                        <strong>{{tableStats.activeOrders}}</strong>
                    </div>
                </section>

                <section class="map-legend" aria-label="Color legend">
                    <span><i class="legend-dot free-dot"></i>Free table</span>
                    <span><i class="legend-dot reserved-dot"></i>Reserved / has order</span>
                </section>

                <section class="table-config-panel" aria-label="Table setup">
                    <div class="config-title">
                        <div>
                            <p class="eyebrow">Setup</p>
                            <h2>Tables configuration</h2>
                        </div>
                        <button type="button" class="secondary-action" id="resetTablesButton">
                            <i class="fa-solid fa-rotate-left"></i>
                            Reset default
                        </button>
                    </div>

                    <form class="table-count-form" id="tableCountForm">
                        <div class="setup-field">
                            <label for="tableCount">Total tables</label>
                            <input type="number" id="tableCount" min="1" value="{{tableStats.totalTables}}" required>
                        </div>
                        <div class="setup-field">
                            <label for="newTableSeats">Seats for new tables</label>
                            <input type="number" id="newTableSeats" min="1" value="4" required>
                        </div>
                        <button type="submit" class="primary-action">
                            <i class="fa-solid fa-table-cells"></i>
                            Apply count
                        </button>
                    </form>

                    <form class="table-setup-form" id="tableSetupForm">
                        <input type="hidden" id="editingTableNumber">
                        <div class="setup-field">
                            <label for="tableNumber">Table</label>
                            <input type="number" id="tableNumber" min="1" required>
                        </div>
                        <div class="setup-field">
                            <label for="tableSeats">Seats</label>
                            <input type="number" id="tableSeats" min="1" required>
                        </div>
                        <div class="setup-field">
                            <label for="tableZone">Zone</label>
                            <input type="text" id="tableZone" list="tableZoneOptions" required>
                            <datalist id="tableZoneOptions">
                                <option value="Terrace"></option>
                                <option value="Main room"></option>
                                <option value="Window side"></option>
                                <option value="Family corner"></option>
                            </datalist>
                        </div>
                        <div class="setup-field">
                            <label for="tableShape">Shape</label>
                            <select id="tableShape" required>
                                <option value="square">Square</option>
                                <option value="round">Round</option>
                            </select>
                        </div>
                        <div class="setup-actions">
                            <button type="submit" class="primary-action" id="saveTableButton">
                                <i class="fa-solid fa-floppy-disk"></i>
                                Add table
                            </button>
                            <button type="button" class="secondary-action" id="cancelTableEdit" hidden>
                                Cancel
                            </button>
                        </div>
                    </form>
                </section>

                <div class="floor-plan">
                    {{#each tableSections}}
                    <section class="floor-zone">
                        <div class="zone-title">
                            <h2>{{title}}</h2>
                            <span>{{freeCount}} free / {{reservedCount}} reserved</span>
                        </div>
                        <div class="table-grid">
                            {{#each tables}}
                            <article class="table-card {{statusClass}}" data-table-number="{{number}}"
                                data-table-seats="{{seats}}" data-table-zone="{{zone}}" data-table-shape="{{shape}}">
                                <div class="table-diagram {{shapeClass}} {{seatsClass}}" aria-label="Table {{number}}">
                                    <span class="chair chair-top"></span>
                                    <span class="chair chair-right"></span>
                                    <span class="chair chair-bottom"></span>
                                    <span class="chair chair-left"></span>
                                    <span class="chair chair-right-extra"></span>
                                    <span class="chair chair-left-extra"></span>
                                    <div class="table-core">T{{number}}</div>
                                </div>
                                <div class="table-info">
                                    <div>
                                        <h3>Table {{number}}</h3>
                                        <span>{{seats}} seats</span>
                                    </div>
                                    <strong>{{statusLabel}}</strong>
                                </div>

                                <div class="table-actions">
                                    <button type="button" class="edit-table-button" data-table-number="{{number}}">
                                        <i class="fa-solid fa-pen"></i>
                                        Edit
                                    </button>
                                    <button type="button" class="delete-table-button" data-table-number="{{number}}">
                                        <i class="fa-solid fa-trash"></i>
                                        Delete
                                    </button>
                                </div>

                                {{#if isReserved}}
                                <div class="order-summary">
                                    <span>{{orderCount}} active</span>
                                    <span>{{activeSeatCount}} seats</span>
                                    <span>{{orderTotal}} DNT</span>
                                </div>
                                {{#if orderKindSummary}}
                                <p class="items-summary">{{orderKindSummary}}</p>
                                {{/if}}
                                {{#if reservationSummary}}
                                <p class="reservation-summary">Reservation: {{reservationSummary}}</p>
                                {{/if}}
                                {{#if itemSummary}}
                                <p class="items-summary">{{itemSummary}}</p>
                                {{/if}}
                                <button class="mark-free-button" data-table-number="{{number}}">
                                    <i class="fa-solid fa-check"></i>
                                    Mark free
                                </button>
                                {{else}}
                                <p class="items-summary">No active order</p>
                                {{/if}}
                            </article>
                            {{/each}}
                        </div>
                    </section>
                    {{/each}}
                </div>
            </main>
        </div>
    </div>

    <div id="statusToast" class="status-toast" role="status" aria-live="polite"></div>

    <script>
        const toast = document.getElementById('statusToast');
        const tableCountForm = document.getElementById('tableCountForm');
        const tableCountInput = document.getElementById('tableCount');
        const newTableSeatsInput = document.getElementById('newTableSeats');
        const tableSetupForm = document.getElementById('tableSetupForm');
        const editingTableNumberInput = document.getElementById('editingTableNumber');
        const tableNumberInput = document.getElementById('tableNumber');
        const tableSeatsInput = document.getElementById('tableSeats');
        const tableZoneInput = document.getElementById('tableZone');
        const tableShapeInput = document.getElementById('tableShape');
        const saveTableButton = document.getElementById('saveTableButton');
        const cancelTableEditButton = document.getElementById('cancelTableEdit');
        const resetTablesButton = document.getElementById('resetTablesButton');

        function showToast(message, type) {
            toast.textContent = message;
            toast.className = `status-toast ${type || 'success'} is-visible`;
            setTimeout(() => {
                toast.classList.remove('is-visible');
            }, 2500);
        }

        async function readResponseError(response) {
            try {
                const data = await response.json();
                return data.error || 'Request failed';
            } catch (error) {
                return 'Request failed';
            }
        }

        function resetTableForm() {
            tableSetupForm.reset();
            editingTableNumberInput.value = '';
            saveTableButton.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Add table';
            cancelTableEditButton.hidden = true;
        }

        function fillTableForm(card) {
            editingTableNumberInput.value = card.dataset.tableNumber;
            tableNumberInput.value = card.dataset.tableNumber;
            tableSeatsInput.value = card.dataset.tableSeats;
            tableZoneInput.value = card.dataset.tableZone;
            tableShapeInput.value = card.dataset.tableShape || 'square';
            saveTableButton.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Update table';
            cancelTableEditButton.hidden = false;
            tableSetupForm.scrollIntoView({ behavior: 'smooth', block: 'center' });
            tableNumberInput.focus();
        }

        tableCountForm.addEventListener('submit', async (event) => {
            event.preventDefault();

            try {
                const response = await fetch('/tables/config/count', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json',
                    },
                    body: JSON.stringify({
                        tableCount: tableCountInput.value,
                        defaultSeats: newTableSeatsInput.value,
                    }),
                });

                if (!response.ok) {
                    throw new Error(await readResponseError(response));
                }

                showToast('Table count updated', 'success');
                setTimeout(() => {
                    window.location.reload();
                }, 700);
            } catch (error) {
                showToast(error.message || 'Could not update table count', 'error');
            }
        });

        tableSetupForm.addEventListener('submit', async (event) => {
            event.preventDefault();

            const editingTableNumber = editingTableNumberInput.value;
            const payload = {
                number: tableNumberInput.value,
                seats: tableSeatsInput.value,
                zone: tableZoneInput.value,
                shape: tableShapeInput.value,
            };

            try {
                const response = await fetch(editingTableNumber ? `/tables/config/${editingTableNumber}` : '/tables/config', {
                    method: editingTableNumber ? 'PATCH' : 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json',
                    },
                    body: JSON.stringify(payload),
                });

                if (!response.ok) {
                    throw new Error(await readResponseError(response));
                }

                showToast(editingTableNumber ? 'Table updated' : 'Table added', 'success');
                setTimeout(() => {
                    window.location.reload();
                }, 700);
            } catch (error) {
                showToast(error.message || 'Could not save table', 'error');
            }
        });

        cancelTableEditButton.addEventListener('click', resetTableForm);

        resetTablesButton.addEventListener('click', async () => {
            const confirmed = confirm('Reset tables to the default cafe setup?');

            if (!confirmed) {
                return;
            }

            resetTablesButton.disabled = true;
            try {
                const response = await fetch('/tables/config/reset', {
                    method: 'POST',
                    headers: {
                        'Accept': 'application/json',
                    },
                });

                if (!response.ok) {
                    throw new Error(await readResponseError(response));
                }

                showToast('Default setup restored', 'success');
                setTimeout(() => {
                    window.location.reload();
                }, 700);
            } catch (error) {
                resetTablesButton.disabled = false;
                showToast(error.message || 'Could not reset tables', 'error');
            }
        });

        document.querySelectorAll('.edit-table-button').forEach((button) => {
            button.addEventListener('click', () => {
                const card = button.closest('.table-card');
                fillTableForm(card);
            });
        });

        document.querySelectorAll('.delete-table-button').forEach((button) => {
            button.addEventListener('click', async () => {
                const tableNumber = button.dataset.tableNumber;
                const confirmed = confirm(`Delete table ${tableNumber}?`);

                if (!confirmed) {
                    return;
                }

                button.disabled = true;
                try {
                    const response = await fetch(`/tables/config/${tableNumber}`, {
                        method: 'DELETE',
                        headers: {
                            'Accept': 'application/json',
                        },
                    });

                    if (!response.ok) {
                        throw new Error(await readResponseError(response));
                    }

                    showToast(`Table ${tableNumber} deleted`, 'success');
                    setTimeout(() => {
                        window.location.reload();
                    }, 700);
                } catch (error) {
                    button.disabled = false;
                    showToast(error.message || 'Could not delete table', 'error');
                }
            });
        });

        document.querySelectorAll('.mark-free-button').forEach((button) => {
            button.addEventListener('click', async () => {
                const tableNumber = button.dataset.tableNumber;
                const confirmed = confirm(`Mark table ${tableNumber} as free?`);

                if (!confirmed) {
                    return;
                }

                button.disabled = true;
                try {
                    const response = await fetch(`/tables/${tableNumber}/free`, {
                        method: 'PATCH',
                        headers: {
                            'Accept': 'application/json',
                        },
                    });

                    if (!response.ok) {
                        throw new Error('Request failed');
                    }

                    showToast(`Table ${tableNumber} is free now`, 'success');
                    setTimeout(() => {
                        window.location.reload();
                    }, 700);
                } catch (error) {
                    button.disabled = false;
                    showToast('Could not update table status', 'error');
                }
            });
        });
    </script>
</body>

</html>
